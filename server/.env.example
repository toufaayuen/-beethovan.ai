# Stripe - for $1 unlimited membership
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...   # Create a $1 one-time product in Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...   # From Stripe Dashboard > Webhooks
