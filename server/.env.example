# Server
PORT=3001

# Auth (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Free AI search - your DeepSeek API key (kept on server, not exposed to users)
DEEPSEEK_API_KEY=sk-...

# Xai AI - for chord chart generation when song not in verified reference (avoids CORS)
XAI_API_KEY=xai-...

# Stripe - subscription ($1/mo or $10/yr)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID_MONTHLY=price_...   # $1/month recurring - create in Stripe Dashboard
STRIPE_PRICE_ID_YEARLY=price_...    # $10/year recurring - create in Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...     # From Stripe Dashboard > Webhooks
